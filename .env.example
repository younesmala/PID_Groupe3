# =========================================
# Configuration du projet PID_Groupe3
# =========================================
# Copiez ce fichier vers .env puis adaptez
# les valeurs selon votre environnement local.
#
# Commande : cp .env.example .env
# =========================================

# --- Django ---
SECRET_KEY=votre-cle-secrete-ici-a-changer-en-production
DEBUG=True
DJANGO_ENV=development

# --- Base de données MySQL ---
# Valeurs par défaut pour MAMP (macOS) :
#   - Host : 127.0.0.1
#   - Port : 3306 (ou 8889 si MAMP sur port alternatif)
#   - User : root
#   - Password : root (ou vide selon la config MAMP)
DB_NAME=reservation
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
